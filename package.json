{
  "name": "react-templates",
  "description": "An empty template of create-next-app.",
  "version": "1.0.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/react-templates.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "unused": "node tools/unused.ts",
    "compile": "tsx --no-cache src/compiler.ts",
    "lint": "eslint",
    "update": "yarn upgrade-interactive",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@goatjs/node": "^1.71.0",
    "@goatjs/node-eslint": "^1.41.0",
    "@goatjs/rimraf": "^1.71.0",
    "@goatjs/ts-unused-exports": "^1.71.0",
    "@goatjs/typescript-config": "^1.71.0",
    "@types/node": "^25.3.0",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yargs": "^18.0.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "dependencies": {
    "@goatjs/dbz": "^1.71.0"
  }
